PORT=3000 # Application port
APP_URL=http://localhost:3000 # Used to generate referral links

MONGO_URI=mongodb://localhost:27017/stock_market_platform?replicaSet=rs0 # MongoDB connection string with replica set

JWT_SECRET=replace_with_secure_secret # JWT signing secret
JWT_EXPIRES_IN=7d # Member/admin access token expiration

OTP_EXPIRES_MINUTES=10 # OTP validity duration in minutes

MAIL_HOST=smtp.gmail.com # SMTP host
MAIL_PORT=587 # SMTP port
MAIL_SECURE=false # false for 587, true for 465
MAIL_USER=your_email@gmail.com # SMTP username
MAIL_PASS=your_gmail_app_password # Gmail app password
MAIL_FROM=your_email@gmail.com # Sender email address

ADMIN_EMAIL=omar.admin@example.com # Seeded admin email
ADMIN_PASSWORD=Admin@123456 # Seeded admin password for local development
ADMIN_FULL_NAME=Omar Admin # Seeded admin full name

# IMPORTANT:
# MongoDB must be initialized as a replica set named rs0.
# This is required because order buy/sell flows use MongoDB sessions/transactions.
