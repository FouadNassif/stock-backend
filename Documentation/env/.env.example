# =========================================================
# Stock Market Platform Environment Template
# =========================================================

# Copy this file to .env and replace placeholder values.
# Never commit real secrets.

# =========================================================
# Application
# =========================================================

# NestJS HTTP port.
PORT=3000

# Public app URL used for generated member referral links.
APP_URL=http://localhost:3000

# =========================================================
# MongoDB
# =========================================================

# Use localhost when running NestJS locally and MongoDB in Docker with exposed ports.
# Services running inside Docker may need the Docker service name instead of localhost.
MONGO_URI=mongodb://localhost:27017/stock_market_platform?replicaSet=rs0

# =========================================================
# JWT / Authentication
# =========================================================

# Shared signing secret for member and admin JWT access tokens.
# Use a long random value with at least 20 characters.
JWT_SECRET=replace-with-secure-random-secret-at-least-20-characters

# Access token expiration used by both member and admin JWT modules.
JWT_EXPIRES_IN=7d

# =========================================================
# OTP
# =========================================================

# OTP validity duration in minutes for email verification and password reset flows.
OTP_EXPIRES_MINUTES=10

# =========================================================
# SMTP / Email
# =========================================================

# SMTP server settings.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false

# SMTP username and password.
# For Gmail, MAIL_PASS should be an app password, not a normal Gmail password.
MAIL_USER=replace-with-email@example.com
MAIL_PASS=replace-with-gmail-app-password

# Sender email address. This must be only an email address.
MAIL_FROM=replace-with-email@example.com
MAIL_FROM_NAME=replace-with-company-name

# =========================================================
# Default Admin Bootstrap
# =========================================================

# Used by the NestJS app to create the first admin if one does not already exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-secure-admin-password
ADMIN_FULL_NAME=Default Admin

# =========================================================
# Redis
# =========================================================

# Local Docker Redis defaults.
REDIS_HOST=localhost
REDIS_PORT=6379

# Leave blank when local Redis has no password.
REDIS_PASSWORD=

# =========================================================
# Redis Cache TTL
# =========================================================

# Cache duration for stock catalogue/detail/current price responses.
CACHE_STOCKS_TTL_SECONDS=300

# Cache duration for member portfolio summary responses.
CACHE_PORTFOLIO_TTL_SECONDS=120

# =========================================================
# Rate Limiting
# =========================================================

# Login rate limits.
RATE_LOGIN_STAGE1_LIMIT=5
RATE_LOGIN_STAGE1_TIME=900
RATE_LOGIN_STAGE2_LIMIT=20
RATE_LOGIN_STAGE2_TIME=900

# Forgot-password rate limits.
RATE_FORGET_STAGE1_LIMIT=3
RATE_FORGET_STAGE1_TIME=900
RATE_FORGET_STAGE2_LIMIT=10
RATE_FORGET_STAGE2_TIME=900

# Registration rate limits.
RATE_REGISTER_STAGE1_LIMIT=3
RATE_REGISTER_STAGE1_TIME=900
RATE_REGISTER_STAGE2_LIMIT=10
RATE_REGISTER_STAGE2_TIME=900

# Verify-OTP rate limits.
RATE_V_OTP_STAGE1_LIMIT=5
RATE_V_OTP_STAGE1_TIME=900
RATE_V_OTP_STAGE2_LIMIT=20
RATE_V_OTP_STAGE2_TIME=900

# Resend-OTP rate limits.
RATE_R_OTP_STAGE1_LIMIT=3
RATE_R_OTP_STAGE1_TIME=900
RATE_R_OTP_STAGE2_LIMIT=10
RATE_R_OTP_STAGE2_TIME=900

# Maximum number of active price alerts one member can have across all stocks
MAX_ACTIVE_PRICE_ALERTS_PER_MEMBER=6

# Maximum number of active price alerts one member can have for the same stock
MAX_ACTIVE_PRICE_ALERTS_PER_STOCK=2

# =========================================================
# Stripe
# =========================================================

# Stripe test secret key and webhook signing secret.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Checkout currency and redirect URLs.
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3000/payments/success
STRIPE_CANCEL_URL=http://localhost:3000/payments/cancel

# =========================================================
# RabbitMQ
# =========================================================

# Local Docker RabbitMQ URL from docker-compose.yml.
RABBITMQ_URL=amqp://stock_market:stock_market_password@localhost:5672

# Queue names used for notification and realtime events.
RABBITMQ_NOTIFICATION_QUEUE=notification_events
RABBITMQ_REALTIME_QUEUE=realtime_events

# =========================================================
# Analytics Service
# =========================================================

# NestJS uses this to proxy protected analytics routes to FastAPI.
# If NestJS runs inside Docker, use the Docker service name instead of localhost.
ANALYTICS_SERVICE_URL=http://localhost:8000

# =========================================================
# FastAPI Analytics Service
# =========================================================

# FastAPI also reads MONGO_URI. Keep it pointed at the same database as NestJS.
# When the FastAPI service runs inside Docker Compose, docker-compose.yml sets MONGO_URI using the mongodb service name.

# =========================================================
# Scheduled Jobs
# =========================================================

# Cron expressions are currently defined in code, not environment variables.

# =========================================================
# Optional URLs
# =========================================================

# Stripe success and cancel callback URLs are configured above.
